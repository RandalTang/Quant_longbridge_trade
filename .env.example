# Longbridge OpenAPI legacy API key authentication.
# Fill these in your shell environment before running the CLI.
LONGBRIDGE_APP_KEY=your_app_key
LONGBRIDGE_APP_SECRET=your_app_secret
LONGBRIDGE_ACCESS_TOKEN=your_access_token

# Optional: override the OpenAPI endpoint.
# LONGBRIDGE_HTTP_URL=https://openapi.longbridge.com

# Optional: Feishu custom bot webhook for signal notifications.
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token
FEISHU_WEBHOOK_SECRET=your_signing_secret_if_enabled
